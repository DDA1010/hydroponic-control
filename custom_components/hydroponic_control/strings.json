          "fan_switch": "Circulation / exhaust fan",
          "heater_switch": "Water heater",
          "floor_leak_sensor": "Floor leak sensor (flood detection)",
          "water_temp_sensor": "Water temperature sensor",
          "air_temp_sensor": "Air / outdoor temperature sensor",
          "humidity_sensor": "Humidity sensor",
          "illuminance_sensor": "Illuminance sensor",
          "pump_power_sensor": "Pump power sensor (fault detection)"
        },
        "data_description": {
          "water_sensor": "A leak/level sensor placed at the minimum water line. Used so the pump never runs dry.",
          "pump_power_sensor": "If the pump plug reports power, Hydroponic Control verifies the pump actually draws current after switching on."
        }
      }
    }
  },
